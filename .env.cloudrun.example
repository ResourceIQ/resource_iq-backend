# Cloud Run environment template for ResourceIQ backend
# Copy values into Secret Manager / Cloud Run env vars.

# Core app
ENVIRONMENT=production
PROJECT_NAME=ResourceIQ Backend
DOMAIN=resource-iq-be-427399139424.asia-south1.run.app
FRONTEND_HOST=https://your-frontend-domain
BACKEND_CORS_ORIGINS=["https://your-frontend-domain"]
API_V1_STR=/api/v1

# Auth
SECRET_KEY=replace_with_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=11520
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=replace_with_strong_password

# Postgres
POSTGRES_SERVER=replace_with_postgres_host
POSTGRES_PORT=5432
POSTGRES_DB=resource-iq
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_db_password
POSTGRES_SSL_MODE=require
#Cloud Run
CLOUD_SQL_CONNECTION_NAME=replace_with_cloud_sql_connection_name

# GitHub integration (required by current Settings)
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=replace_with_webhook_secret
GITHUB_APP_SLUG=resourceiq-dev

# Jina embedding API
USE_JINA_API=true
JINA_API_KEY=replace_with_jina_api_key
JINA_API_URL=https://api.jina.ai
JINA_EMBEDDING_MODEL1=jina-code-embeddings-0.5b
JINA_EMBEDDING_MODEL2=jinaai/jina-code-embeddings-0.5b
EMBEDDING_DIMENSION=1536

# Optional: Sentry
SENTRY_DSN=

# Optional: SMTP
SMTP_TLS=true
SMTP_SSL=false
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=ResourceIQ
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48

# Optional: Neo4j knowledge graph
NEO4J_SCHEME=neo4j+s
NEO4J_HOST=
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional: Vertex AI / GCP
GCP_PROJECT_ID=resource-iq-be
GCP_LOCATION=asia-south1
# In Cloud Run, prefer service account ADC and keep this empty.
GCP_CREDENTIALS_PATH=

# Optional: Jira API token mode
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# Optional: Atlassian OAuth mode
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=
ATLASSIAN_AUTH_URL=https://auth.atlassian.com/authorize
ATLASSIAN_TOKEN_URL=https://auth.atlassian.com/oauth/token
ATLASSIAN_API_AUDIENCE=api.atlassian.com
ATLASSIAN_SCOPES=["read:jira-work","write:jira-work","read:jira-user","offline_access"]
